{
  "datasets": [
    {
      "name": "34922cea",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "SELECT * FROM silver.earthquake_data_final"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "1b383a4c",
      "displayName": "EarthQuake_Type",
      "queryLines": [
        "SELECT COUNT(*) AS total_magnitude_bucket\r\n",
        ", magnitude_bucket from (\r\n",
        "    SELECT CASE\r\n",
        "        WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "        WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2-3)'\r\n",
        "        WHEN mag BETWEEN 3 AND 4 THEN 'Light (3-4)'\r\n",
        "        ELSE 'Moderate+ (4+)'\r\n",
        "END AS magnitude_bucket\r\n",
        "FROM silver.earthquake_data_final\r\n",
        ") group by magnitude_bucket"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "fab88ed1",
      "displayName": "EarthQuake_Country",
      "queryLines": [
        "SELECT \r\n",
        "    COUNT(*) AS event_count,\r\n",
        "    -- CASE \r\n",
        "    --     WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\r\n",
        "    --     ELSE split(place, ', ')[1]\r\n",
        "    -- END AS country\r\n",
        "    get(split(place, ', '), 1) as country\r\n",
        "FROM (\r\n",
        "    SELECT\r\n",
        "        time, \r\n",
        "        title,\r\n",
        "        mag,\r\n",
        "        longitude,\r\n",
        "        place,\r\n",
        "        latitude\r\n",
        "    FROM silver.earthquake_data_final\r\n",
        ") \r\n",
        "GROUP BY country"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    }
  ],
